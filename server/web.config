<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
 
    <!-- Disable WebDAV module -->
    <modules>
      <remove name="WebDAVModule" />
    </modules>
 
    <handlers>
      <remove name="WebDAV" />
 
      <!-- iisnode handler for Node.js -->
      <add name="iisnode" path="index.js" verb="*" modules="iisnode" />
 
      <!-- Allow all verbs for extensionless URLs -->
      <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
      <add name="ExtensionlessUrlHandler-Integrated-4.0"
           path="*."
           verb="GET,HEAD,POST,DEBUG,PUT,DELETE,OPTIONS,PATCH"
           type="System.Web.Handlers.TransferRequestHandler"
           preCondition="integratedMode,runtimeVersionv4.0" />
    </handlers>
 
    <!-- Minimal, schema-safe iisnode section -->
    <iisnode devErrorsEnabled="true" />
 
    <!-- <iisnode loggingEnabled="true" nodeProcessCommandLine="C:\Program Files\nodejs\node.exe" maxIdleTimeInSeconds="0" /> -->
 
    <!-- Rewrite everything to Server.js -->
    <rewrite>
      <rules>
        <rule name="nodejs" stopProcessing="true">
          <match url="(.*)" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="/index.js" />
        </rule>
      </rules>
    </rewrite>
 
    <!-- Allow all REST verbs -->
    <security>
      <requestFiltering>
        <verbs allowUnlisted="true">
          <add verb="GET" allowed="true" />
          <add verb="POST" allowed="true" />
          <add verb="PUT" allowed="true" />
          <add verb="DELETE" allowed="true" />
          <add verb="PATCH" allowed="true" />
          <add verb="OPTIONS" allowed="true" />
        </verbs>
        <hiddenSegments>
          <add segment="node_modules" />
          <add segment="iisnode" />
        </hiddenSegments>
      </requestFiltering>
    </security>
 
  </system.webServer>
</configuration>
 